# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────
APP_NAME=CrowdIQ
APP_VERSION=1.0.0
DEBUG=false    # Set to true for local development only

# ─────────────────────────────────────────────
# DATABASE (Supabase PostgreSQL)
# Get from: https://app.supabase.com → Project Settings → Database → Connection string
# Use the "URI" format with asyncpg driver
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database_name

# ─────────────────────────────────────────────
# REDIS (Upstash — HTTP REST client, NOT TCP)
# Get from: https://console.upstash.com → Create Database → REST API
# ─────────────────────────────────────────────
REDIS_URL=https://your-instance.upstash.io
REDIS_TOKEN=your_upstash_rest_token

# ─────────────────────────────────────────────
# FIREBASE
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
# For Cloud Run: this file is mounted as a secret at /app/firebase-service-account.json
# For local dev: place the file at backend/firebase-service-account.json (gitignored)
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ─────────────────────────────────────────────
# GOOGLE MAPS
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Required APIs: Maps JavaScript API, Directions API
# ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─────────────────────────────────────────────
# GOOGLE TRANSLATE (Basic API)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Free tier: 500,000 characters/month
# ─────────────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# Optional helper credentials for local demo seeding scripts only.
# Do not commit real values.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me_before_running_seed_scripts

# ─────────────────────────────────────────────
# SECURITY
# SECRET_KEY: generate with: python -c "import secrets; print(secrets.token_hex(64))"
# ALLOWED_ORIGINS: comma-separated list of allowed frontend origins
# ─────────────────────────────────────────────
SECRET_KEY=generate_a_64_character_random_hex_string_here
ALGORITHM=HS256
ALLOWED_ORIGINS=https://your-project.web.app,http://localhost:5173
